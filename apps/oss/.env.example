# Next.js frontend (apps/oss) — copy to .env.local and adjust as needed.

# URL of the Rust backend API. Used whenever the Supabase demo store below
# is NOT configured. Defaults to http://localhost:8080 if unset.
NEXT_PUBLIC_BACKEND_URL=http://localhost:8080

# --- Public demo mode (Vercel) ---
# Set BOTH of these to make the Next.js API routes read/write Supabase
# instead of the Rust backend. Leave unset for normal local development
# against the Rust backend.
# SPARKTEST_SUPABASE_URL=
# SPARKTEST_SUPABASE_SERVICE_ROLE_KEY=

# Optional. If set, write requests (POST/PATCH/DELETE) to the Supabase demo
# store routes require this value as a `Bearer` token in the Authorization
# header. Only meaningful when the Supabase vars above are set.
# SPARKTEST_DEMO_WRITE_TOKEN=
